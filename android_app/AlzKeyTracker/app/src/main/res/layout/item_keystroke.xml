<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="16dp" android:paddingVertical="10dp">

    <TextView android:id="@+id/tv_key"
        android:layout_width="36dp" android:layout_height="wrap_content"
        android:textSize="16sp" android:textStyle="bold"
        android:textColor="@color/primary" android:fontFamily="monospace"/>

    <TextView android:id="@+id/tv_timing"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textSize="12sp"
        android:textColor="@color/text_secondary" android:fontFamily="monospace"/>

    <TextView android:id="@+id/tv_time"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="11sp" android:textColor="@color/text_secondary"/>

</LinearLayout>