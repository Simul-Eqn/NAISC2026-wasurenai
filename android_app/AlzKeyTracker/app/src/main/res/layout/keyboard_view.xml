<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@color/keyboard_bg" android:padding="4dp">

    <!-- Number row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
        android:orientation="horizontal" android:layout_marginBottom="3dp">
        <Button android:id="@+id/key_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="1" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="2" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="3" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="4" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="5" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="6" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="7" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="8" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="9" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="0" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
    </LinearLayout>

    <!-- QWERTY row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
        android:orientation="horizontal" android:layout_marginBottom="3dp">
        <Button android:id="@+id/key_q" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="q" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_w" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="w" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_e" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="e" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_r" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="r" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_t" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="t" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_y" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="y" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_u" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="u" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_i" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="i" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_o" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="o" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_p" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="p" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
    </LinearLayout>

    <!-- ASDF row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
        android:orientation="horizontal" android:layout_marginBottom="3dp"
        android:paddingStart="18dp" android:paddingEnd="18dp">
        <Button android:id="@+id/key_a" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="a" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_s" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="s" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_d" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="d" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_f" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="f" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_g" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="g" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_h" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="h" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_j" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="j" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_k" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="k" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_l" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="l" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
    </LinearLayout>

    <!-- ZXCV row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
        android:orientation="horizontal" android:layout_marginBottom="3dp">
        <Button android:id="@+id/key_shift" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:layout_margin="2dp" android:text="⇧" android:textSize="16sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_special" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_z" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="z" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_x" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="x" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_c" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="c" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_v" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="v" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_b" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="b" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_n" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="n" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_m" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="m" android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_normal" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_backspace" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:layout_margin="2dp" android:text="⌫" android:textSize="16sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_special" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
    </LinearLayout>

    <!-- Bottom row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
        android:orientation="horizontal">
        <Button android:id="@+id/key_switch_kb" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:layout_margin="2dp" android:text="⌨" android:textSize="18sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_special" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_comma" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="," android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_special" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_space" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" android:layout_margin="2dp" android:text="SPACE" android:textSize="11sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_special" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_period" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="." android:textSize="14sp" android:textColor="@color/key_text" android:backgroundTint="@color/key_special" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/key_enter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2" android:layout_margin="2dp" android:text="↵" android:textSize="16sp" android:textColor="@color/white" android:backgroundTint="@color/key_enter" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
    </LinearLayout>

</LinearLayout>