<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#263238"
    android:padding="4dp">

    <!-- Number row: 1 2 3 4 5 6 7 8 9 0 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
        android:orientation="horizontal" android:layout_marginBottom="3dp">
        <Button android:id="@+id/key_1" style="@style/KeyButton" android:text="1"/>
        <Button android:id="@+id/key_2" style="@style/KeyButton" android:text="2"/>
        <Button android:id="@+id/key_3" style="@style/KeyButton" android:text="3"/>
        <Button android:id="@+id/key_4" style="@style/KeyButton" android:text="4"/>
        <Button android:id="@+id/key_5" style="@style/KeyButton" android:text="5"/>
        <Button android:id="@+id/key_6" style="@style/KeyButton" android:text="6"/>
        <Button android:id="@+id/key_7" style="@style/KeyButton" android:text="7"/>
        <Button android:id="@+id/key_8" style="@style/KeyButton" android:text="8"/>
        <Button android:id="@+id/key_9" style="@style/KeyButton" android:text="9"/>
        <Button android:id="@+id/key_0" style="@style/KeyButton" android:text="0"/>
    </LinearLayout>

    <!-- QWERTY row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
        android:orientation="horizontal" android:layout_marginBottom="3dp">
        <Button android:id="@+id/key_q" style="@style/KeyButton" android:text="q"/>
        <Button android:id="@+id/key_w" style="@style/KeyButton" android:text="w"/>
        <Button android:id="@+id/key_e" style="@style/KeyButton" android:text="e"/>
        <Button android:id="@+id/key_r" style="@style/KeyButton" android:text="r"/>
        <Button android:id="@+id/key_t" style="@style/KeyButton" android:text="t"/>
        <Button android:id="@+id/key_y" style="@style/KeyButton" android:text="y"/>
        <Button android:id="@+id/key_u" style="@style/KeyButton" android:text="u"/>
        <Button android:id="@+id/key_i" style="@style/KeyButton" android:text="i"/>
        <Button android:id="@+id/key_o" style="@style/KeyButton" android:text="o"/>
        <Button android:id="@+id/key_p" style="@style/KeyButton" android:text="p"/>
    </LinearLayout>

    <!-- ASDF row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
        android:orientation="horizontal" android:layout_marginBottom="3dp"
        android:paddingStart="16dp" android:paddingEnd="16dp">
        <Button android:id="@+id/key_a" style="@style/KeyButton" android:text="a"/>
        <Button android:id="@+id/key_s" style="@style/KeyButton" android:text="s"/>
        <Button android:id="@+id/key_d" style="@style/KeyButton" android:text="d"/>
        <Button android:id="@+id/key_f" style="@style/KeyButton" android:text="f"/>
        <Button android:id="@+id/key_g" style="@style/KeyButton" android:text="g"/>
        <Button android:id="@+id/key_h" style="@style/KeyButton" android:text="h"/>
        <Button android:id="@+id/key_j" style="@style/KeyButton" android:text="j"/>
        <Button android:id="@+id/key_k" style="@style/KeyButton" android:text="k"/>
        <Button android:id="@+id/key_l" style="@style/KeyButton" android:text="l"/>
    </LinearLayout>

    <!-- ZXCV row + shift + backspace -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
        android:orientation="horizontal" android:layout_marginBottom="3dp">
        <Button android:id="@+id/key_shift" style="@style/SpecialKeyButton"
            android:layout_width="0dp" android:layout_weight="1.5" android:text="⇧"/>
        <Button android:id="@+id/key_z" style="@style/KeyButton" android:text="z"/>
        <Button android:id="@+id/key_x" style="@style/KeyButton" android:text="x"/>
        <Button android:id="@+id/key_c" style="@style/KeyButton" android:text="c"/>
        <Button android:id="@+id/key_v" style="@style/KeyButton" android:text="v"/>
        <Button android:id="@+id/key_b" style="@style/KeyButton" android:text="b"/>
        <Button android:id="@+id/key_n" style="@style/KeyButton" android:text="n"/>
        <Button android:id="@+id/key_m" style="@style/KeyButton" android:text="m"/>
        <Button android:id="@+id/key_backspace" style="@style/SpecialKeyButton"
            android:layout_width="0dp" android:layout_weight="1.5" android:text="⌫"/>
    </LinearLayout>

    <!-- Bottom row: switch kb, comma, space, period, enter -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal">
        <Button android:id="@+id/key_switch_kb" style="@style/SpecialKeyButton"
            android:layout_width="0dp" android:layout_weight="1.5" android:text="⌨"
            android:textSize="18sp"/>
        <Button android:id="@+id/key_comma" style="@style/SpecialKeyButton"
            android:layout_width="0dp" android:layout_weight="1" android:text=","/>
        <Button android:id="@+id/key_space" style="@style/SpecialKeyButton"
            android:layout_width="0dp" android:layout_weight="5" android:text="SPACE"
            android:textSize="11sp"/>
        <Button android:id="@+id/key_period" style="@style/SpecialKeyButton"
            android:layout_width="0dp" android:layout_weight="1" android:text="."/>
        <Button android:id="@+id/key_enter" style="@style/SpecialKeyButton"
            android:layout_width="0dp" android:layout_weight="2" android:text="↵"
            android:backgroundTint="#1A237E"/>
    </LinearLayout>

</LinearLayout>