<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Before We Begin" android:textSize="26sp" android:textStyle="bold"
            android:textColor="@color/primary" android:layout_marginBottom="6dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Wasurenai — Informed Consent" android:textSize="14sp"
            android:textColor="@color/text_secondary" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="15sp" android:textColor="@color/text_primary"
            android:lineSpacingExtra="5dp" android:layout_marginBottom="24dp"
            android:text="This app records the timing of your keystrokes to support research into early detection of cognitive decline, including Alzheimer's disease.\n\nWhat we collect:\n  • Which keys you press\n  • How long you hold each key\n  • The pauses between keystrokes\n  • Which app you were typing in\n\nWhat we do NOT collect:\n  • The content of your messages\n  • Passwords or personal text\n  • Your name or location\n\nAll data is stored only on this device. You can delete it at any time.\n\nParticipation is voluntary. You may withdraw at any time by disabling the keyboard in your device Settings.\n\nBy tapping I Agree, you confirm you have read and understood this notice."/>

        <Button android:id="@+id/btn_agree" android:layout_width="match_parent"
            android:layout_height="56dp" android:text="I Agree — Continue"
            android:backgroundTint="@color/primary" android:textColor="@color/white"
            android:textSize="16sp" android:layout_marginBottom="12dp"/>

        <Button android:id="@+id/btn_decline" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="Decline — Exit"
            android:backgroundTint="@color/divider" android:textColor="@color/text_secondary"/>

    </LinearLayout>
</ScrollView>